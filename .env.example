# monAI — Environment Variables
#
# Copy this file to .env and fill in the values.
# Only OPENAI_API_KEY is required. Everything else is optional.

# ─── LLM Access (at least one required) ──────────────────────
# OpenAI API key for GPT-4o / GPT-4o-mini / GPT-4.1-nano
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# Anthropic API key (optional alternative)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ─── Config Encryption (optional) ────────────────────────────
# Passphrase for encrypting sensitive config values at rest.
# If not set, monAI auto-generates and stores a key at ~/.monai/.config_key
# MONAI_CONFIG_KEY=your-passphrase-here
